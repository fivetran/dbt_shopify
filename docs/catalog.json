r_customer", "comment": "Whether the discount can be used only once per customer."}, "usage_count": {"type": "integer", "index": 5, "name": "usage_count", "comment": "Number of times the discount has been used (asynchronously updated)."}, "codes_count": {"type": "integer", "index": 6, "name": "codes_count", "comment": "Number of unique redeem codes associated with the discount."}, "codes_precision": {"type": "character varying", "index": 7, "name": "codes_precision", "comment": "Indicates whether `codes_count` is exact or estimated."}, "combines_with_order_discounts": {"type": "boolean", "index": 8, "name": "combines_with_order_discounts", "comment": "Whether this discount can be combined with order-level discounts."}, "combines_with_product_discounts": {"type": "boolean", "index": 9, "name": "combines_with_product_discounts", "comment": "Whether this discount can be combined with product-level discounts."}, "combines_with_shipping_discounts": {"type": "boolean", "index": 10, "name": "combines_with_shipping_discounts", "comment": "Whether this discount can be combined with shipping-level discounts."}, "created_at": {"type": "timestamp without time zone", "index": 11, "name": "created_at", "comment": "Timestamp when the discount was created."}, "customer_selection_all_customers": {"type": "boolean", "index": 12, "name": "customer_selection_all_customers", "comment": "Whether the discount is available to all customers."}, "ends_at": {"type": "timestamp without time zone", "index": 13, "name": "ends_at", "comment": "Timestamp when the discount ends or expires."}, "starts_at": {"type": "timestamp without time zone", "index": 14, "name": "starts_at", "comment": "Timestamp when the discount becomes active."}, "status": {"type": "character varying", "index": 15, "name": "status", "comment": "Current status of the discount (e.g. 'active', 'expired', 'scheduled')."}, "title": {"type": "text", "index": 16, "name": "title", "comment": "The discount\u2019s display name in the Shopify admin and to customers."}, "total_sales_amount": {"type": "double precision", "index": 17, "name": "total_sales_amount", "comment": "The total sales amount that resulted from the usage of this discount."}, "total_sales_currency_code": {"type": "character varying", "index": 18, "name": "total_sales_currency_code", "comment": "The currency code associated with `total_sales_amount`."}, "updated_at": {"type": "timestamp without time zone", "index": 19, "name": "updated_at", "comment": "Timestamp when the discount was last updated."}, "usage_limit": {"type": "integer", "index": 20, "name": "usage_limit", "comment": "The total number of times the discount code can be used."}, "code": {"type": "character varying", "index": 21, "name": "code", "comment": "The case-insensitive discount code that customers use at checkout."}, "allocation_method": {"type": "character varying", "index": 22, "name": "allocation_method", "comment": "The method by which the discount is allocated. Valid values include `each` (applies the discount to each eligible item) and `across` (spreads the discount value across eligible items).\n"}, "description": {"type": "character varying", "index": 23, "name": "description", "comment": "A description of the discount, often corresponding to the rule or promotion name."}, "target_selection": {"type": "character varying", "index": 24, "name": "target_selection", "comment": "Indicates whether the discount applies to 'all' or 'entitled' items."}, "target_type": {"type": "character varying", "index": 25, "name": "target_type", "comment": "The type of target this discount applies to (e.g., `line_item` or `shipping_line`)."}, "application_type": {"type": "character varying", "index": 26, "name": "application_type", "comment": "The type of discount (e.g., `manual`, `script`, or `automatic`)."}, "value": {"type": "double precision", "index": 27, "name": "value", "comment": "Numeric value of the discount (e.g., percentage or fixed amount)."}, "value_type": {"type": "character varying", "index": 28, "name": "value_type", "comment": "How the discount value is interpreted (e.g., 'percentage', 'fixed_amount')."}, "discounts_unique_key": {"type": "text", "index": 29, "name": "discounts_unique_key", "comment": "Unique key representing a discount.\nHashed on 'source_relation', 'discount_code_id', 'discount_id', 'discount_type',\n'code', 'allocation_method', 'description', 'target_selection', 'target_type',\n'type', 'value', 'value_type'.\n"}, "count_orders": {"type": "bigint", "index": 30, "name": "count_orders", "comment": "Count of orders in which this discount code was applied."}, "avg_order_discount_amount": {"type": "double precision", "index": 31, "name": "avg_order_discount_amount", "comment": "Average amount (in shop currency) of discount taken off orders."}, "total_order_discount_amount": {"type": "double precision", "index": 32, "name": "total_order_discount_amount", "comment": "Total monetary amount (in shop currency) of discounts taken off of orders."}, "total_order_line_items_price": {"type": "double precision", "index": 33, "name": "total_order_line_items_price", "comment": "Total monetary amount (in shop currency) of line items for orders that have used this discount."}, "total_order_shipping_cost": {"type": "double precision", "index": 34, "name": "total_order_shipping_cost", "comment": "Total shipping costs for orders that used this discount."}, "total_order_refund_amount": {"type": "double precision", "index": 35, "name": "total_order_refund_amount", "comment": "Total refunded amount (in shop currency) for orders that used this discount code."}, "count_customers": {"type": "bigint", "index": 36, "name": "count_customers", "comment": "Count of distinct customers who placed orders using this discount."}, "count_customer_emails": {"type": "bigint", "index": 37, "name": "count_customer_emails", "comment": "Count of distinct customer emails who placed orders using this discount."}, "total_abandoned_checkout_discount_amount": {"type": "double precision", "index": 38, "name": "total_abandoned_checkout_discount_amount", "comment": "Total monetary amount (in shop currency) of discounts taken off abandoned checkout orders."}, "total_abandoned_checkout_shipping_price": {"type": "double precision", "index": 39, "name": "total_abandoned_checkout_shipping_price", "comment": "Total projected shipping costs for abandoned checkouts that applied this discount first."}, "count_abandoned_checkouts": {"type": "bigint", "index": 40, "name": "count_abandoned_checkouts", "comment": "Count of abandoned checkouts in which this discount code was applied."}, "count_abandoned_checkout_customers": {"type": "bigint", "index": 41, "name": "count_abandoned_checkout_customers", "comment": "Distinct count of customers who applied this discount in a checkout that they abandoned."}, "count_abandoned_checkout_customer_emails": {"type": "bigint", "index": 42, "name": "count_abandoned_checkout_customer_emails", "comment": "Distinct count of customer emails who applied this discount in a checkout that they abandoned."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify__discounts"}, "model.shopify.shopify__inventory_levels": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify__inventory_levels", "database": "postgres", "comment": "Model representing the current status of an inventory level in Shopify. Inventory Levels are unique pairings of  inventory items (which have a 1:1 relationship with product variants) and locations. \nInventory Level = Inventory item @ a Location.\nWill also include `PRODUCT_VARIANT` metafields if enabled.\n", "owner": "postgres"}, "columns": {"inventory_level_id": {"type": "bigint", "index": 1, "name": "inventory_level_id", "comment": null}, "inventory_item_id": {"type": "bigint", "index": 2, "name": "inventory_item_id", "comment": "The ID of the inventory item associated with the inventory level."}, "location_id": {"type": "bigint", "index": 3, "name": "location_id", "comment": "The ID of the location that the inventory level belongs to."}, "can_deactivate": {"type": "boolean", "index": 4, "name": "can_deactivate", "comment": "Indicates whether the inventory item can be deactivated at the location."}, "deactivation_alert": {"type": "text", "index": 5, "name": "deactivation_alert", "comment": "Provides an alert message when the inventory item is deactivated at the location."}, "created_at": {"type": "timestamp without time zone", "index": 6, "name": "created_at", "comment": "The date and time when the inventory level was created."}, "updated_at": {"type": "timestamp without time zone", "index": 7, "name": "updated_at", "comment": "The date and time (ISO 8601 format) when the inventory level was last modified."}, "_fivetran_synced": {"type": "timestamp without time zone", "index": 8, "name": "_fivetran_synced", "comment": "The time when a record was last updated by Fivetran."}, "source_relation": {"type": "text", "index": 9, "name": "source_relation", "comment": "The schema or database this record came from if you are making use of the `shopify_union_schemas` or `shopify_union_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}, "sku": {"type": "text", "index": 10, "name": "sku", "comment": "The unique SKU (stock keeping unit) of the inventory item."}, "is_inventory_item_deleted": {"type": "boolean", "index": 11, "name": "is_inventory_item_deleted", "comment": "Boolean representing whether the record was soft-deleted in Shopify."}, "unit_cost_amount": {"type": "double precision", "index": 12, "name": "unit_cost_amount", "comment": "The unit cost associated with the inventory item."}, "unit_cost_currency_code": {"type": "integer", "index": 13, "name": "unit_cost_currency_code", "comment": "Currency of the unit cost associated with the inventory item."}, "country_code_of_origin": {"type": "integer", "index": 14, "name": "country_code_of_origin", "comment": "The country code (ISO 3166-1 alpha-2) of where the item came from."}, "province_code_of_origin": {"type": "integer", "index": 15, "name": "province_code_of_origin", "comment": "The province code (ISO 3166-2 alpha-2) of where the item came from. The province code is only used if the shipping provider for the inventory item is Canada Post."}, "is_shipping_required": {"type": "boolean", "index": 16, "name": "is_shipping_required", "comment": "(DEPRECATED 2025-01-06) Boolean representing whether a customer needs to provide a shipping address when placing an order containing the inventory item."}, "is_inventory_quantity_tracked": {"type": "boolean", "index": 17, "name": "is_inventory_quantity_tracked", "comment": "Boolean representing whether inventory levels are tracked for the item. If true, then the inventory quantity changes are tracked by Shopify."}, "inventory_item_created_at": {"type": "timestamp without time zone", "index": 18, "name": "inventory_item_created_at", "comment": "The date and time (ISO 8601 format) when the inventory item was created."}, "inventory_item_updated_at": {"type": "timestamp without time zone", "index": 19, "name": "inventory_item_updated_at", "comment": "The date and time (ISO 8601 format) when the inventory item was last modified."}, "duplicate_sku_count": {"type": "integer", "index": 20, "name": "duplicate_sku_count", "comment": "The number of inventory items that share the same SKU with this item."}, "harmonized_system_code": {"type": "integer", "index": 21, "name": "harmonized_system_code", "comment": "The harmonized system code of the item."}, "inventory_history_url": {"type": "text", "index": 22, "name": "inventory_history_url", "comment": "The URL that points to the inventory history for the item."}, "legacy_resource_id": {"type": "bigint", "index": 23, "name": "legacy_resource_id", "comment": "The ID of the corresponding resource in the REST Admin API."}, "measurement_id": {"type": "bigint", "index": 24, "name": "measurement_id", "comment": "The unique identifier for the inventory item's measurement."}, "measurement_weight_value": {"type": "integer", "index": 25, "name": "measurement_weight_value", "comment": "The weight value of the inventory item's measurement."}, "measurement_weight_unit": {"type": "text", "index": 26, "name": "measurement_weight_unit", "comment": "The unit of measurement for the inventory item's weight."}, "is_tracked_editable_locked": {"type": "integer", "index": 27, "name": "is_tracked_editable_locked", "comment": "Indicates whether the 'tracked' field for the inventory item is locked from editing."}, "tracked_editable_reason": {"type": "integer", "index": 28, "name": "tracked_editable_reason", "comment": "Provides the reason why the 'tracked' field for the inventory item is locked from editing."}, "location_name": {"type": "text", "index": 29, "name": "location_name", "comment": "The name of the location."}, "is_location_deleted": {"type": "boolean", "index": 30, "name": "is_location_deleted", "comment": "Boolean representing whether the record was soft-deleted in Shopify."}, "is_location_active": {"type": "boolean", "index": 31, "name": "is_location_active", "comment": "Boolean representing whether the location is active. If true, then the location can be used to sell products, stock inventory, and fulfill orders.\n"}, "address_1": {"type": "text", "index": 32, "name": "address_1", "comment": "The location's street address."}, "address_2": {"type": "integer", "index": 33, "name": "address_2", "comment": "The optional second line of the location's street address."}, "city": {"type": "text", "index": 34, "name": "city", "comment": "The city the location is in."}, "country": {"type": "text", "index": 35, "name": "country", "comment": "The country the location is in (two-letter code)."}, "country_code": {"type": "text", "index": 36, "name": "country_code", "comment": "The two-letter code (ISO 3166-1 alpha-2 format) corresponding to country the location is in."}, "is_legacy_location": {"type": "boolean", "index": 37, "name": "is_legacy_location", "comment": "Boolean representing whether this is a fulfillment service location. If true, then the location is a fulfillment service location.  If false, then the location was created by the merchant and isn't tied to a fulfillment service.\n"}, "province": {"type": "text", "index": 38, "name": "province", "comment": "The province, state, or district of the location."}, "province_code": {"type": "text", "index": 39, "name": "province_code", "comment": "The province, state, or district code (ISO 3166-2 alpha-2 format) of the location."}, "phone": {"type": "integer", "index": 40, "name": "phone", "comment": "The phone number of the location. This value can contain special characters, such as - or +."}, "zip": {"type": "integer", "index": 41, "name": "zip", "comment": "The zip or postal code."}, "location_created_at": {"type": "timestamp without time zone", "index": 42, "name": "location_created_at", "comment": "The date and time (ISO 8601 format) when the location was created."}, "location_updated_at": {"type": "timestamp without time zone", "index": 43, "name": "location_updated_at", "comment": "The date and time (ISO 8601 format) when the location was last updated."}, "variant_id": {"type": "bigint", "index": 44, "name": "variant_id", "comment": "The unique numeric identifier for the product variant."}, "product_id": {"type": "bigint", "index": 45, "name": "product_id", "comment": "The unique numeric identifier for the product."}, "variant_title": {"type": "text", "index": 46, "name": "variant_title", "comment": "The title of the product variant. The title field is a concatenation of the option1, option2, and option3 fields. You can only update title indirectly using the option fields."}, "variant_inventory_policy": {"type": "text", "index": 47, "name": "variant_inventory_policy", "comment": "Whether customers are allowed to place an order for the product variant when it's out of stock."}, "variant_price": {"type": "double precision", "index": 48, "name": "variant_price", "comment": "The price of the product variant in shop currency."}, "variant_media_id": {"type": "bigint", "index": 49, "name": "variant_media_id", "comment": "The unique numeric identifier for a product variant's media."}, "variant_fulfillment_service": {"type": "text", "index": 50, "name": "variant_fulfillment_service", "comment": "(DEPRECATED 2025-01-06) The fulfillment service associated with the product variant."}, "variant_inventory_management": {"type": "text", "index": 51, "name": "variant_inventory_management", "comment": "(DEPRECATED 2025-01-06) The fulfillment service that tracks the number of items in stock for the product variant."}, "is_variant_taxable": {"type": "boolean", "index": 52, "name": "is_variant_taxable", "comment": "Whether a tax is charged when the product variant is sold."}, "variant_barcode": {"type": "integer", "index": 53, "name": "variant_barcode", "comment": "The barcode, UPC, or ISBN number for the product."}, "variant_grams": {"type": "double precision", "index": 54, "name": "variant_grams", "comment": "(DEPRECATED 2025-01-06) The weight of the product variant in grams."}, "variant_inventory_quantity": {"type": "numeric", "index": 55, "name": "variant_inventory_quantity", "comment": "An aggregate of inventory across all locations. To adjust inventory at a specific location, use the InventoryLevel resource."}, "variant_weight": {"type": "double precision", "index": 56, "name": "variant_weight", "comment": "(DEPRECATED 2025-01-06) The weight of the product variant in the unit system specified with weight_unit."}, "variant_weight_unit": {"type": "text", "index": 57, "name": "variant_weight_unit", "comment": "(DEPRECATED 2025-01-06) The unit of measurement that applies to the product variant's weight. If you don't specify a value for weight_unit, then the shop's default unit of measurement is applied. Valid values: g, kg, oz, and lb.\n"}, "variant_option_1": {"type": "text", "index": 58, "name": "variant_option_1", "comment": "(DEPRECATED 2025-01-06) The custom properties that a shop owner uses to define product variants. You can define three options for a product variant: option1, option2, option3. \n"}, "variant_option_2": {"type": "text", "index": 59, "name": "variant_option_2", "comment": "(DEPRECATED 2025-01-06) The custom properties that a shop owner uses to define product variants. You can define three options for a product variant: option1, option2, option3.\n"}, "variant_option_3": {"type": "text", "index": 60, "name": "variant_option_3", "comment": "(DEPRECATED 2025-01-06) The custom properties that a shop owner uses to define product variants. You can define three options for a product variant: option1, option2, option3.\n"}, "variant_tax_code": {"type": "integer", "index": 61, "name": "variant_tax_code", "comment": "This parameter applies only to the stores that have the Avalara AvaTax app installed. Specifies the Avalara tax code for the product variant."}, "variant_created_at": {"type": "timestamp without time zone", "index": 62, "name": "variant_created_at", "comment": "The date and time (ISO 8601 format) when the product variant was created."}, "variant_updated_at": {"type": "timestamp without time zone", "index": 63, "name": "variant_updated_at", "comment": "The date and time when the product variant was last modified. Gets returned in ISO 8601 format."}, "variant_is_available_for_sale": {"type": "boolean", "index": 64, "name": "variant_is_available_for_sale", "comment": "Indicates whether the product variant is available for sale."}, "variant_display_name": {"type": "text", "index": 65, "name": "variant_display_name", "comment": "The display name of the variant, based on the product's title and variant's title."}, "variant_legacy_resource_id": {"type": "bigint", "index": 66, "name": "variant_legacy_resource_id", "comment": "The ID of the corresponding resource in the REST Admin API."}, "variant_has_components_required": {"type": "boolean", "index": 67, "name": "variant_has_components_required", "comment": "Indicates whether a product variant requires components."}, "variant_sellable_online_quantity": {"type": "integer", "index": 68, "name": "variant_sellable_online_quantity", "comment": "The total sellable quantity of the variant for online channels."}, "variant_metafield_blade_runner_returnauthorizations": {"type": "text", "index": 69, "name": "variant_metafield_blade_runner_returnauthorizations", "comment": null}, "variant_metafield_avengers_wherearethey": {"type": "text", "index": 70, "name": "variant_metafield_avengers_wherearethey", "comment": null}, "variant_metafield_star_wars_wheninspace": {"type": "text", "index": 71, "name": "variant_metafield_star_wars_wheninspace", "comment": null}, "subtotal_sold": {"type": "bigint", "index": 72, "name": "subtotal_sold", "comment": "Total amount (monetary, in shop currency) sold from the inventory level. Includes refunds."}, "quantity_sold": {"type": "bigint", "index": 73, "name": "quantity_sold", "comment": "Total quantity sold from the inventory level. Includes refunds."}, "count_distinct_orders": {"type": "bigint", "index": 74, "name": "count_distinct_orders", "comment": "The number of distinct orders placed from this inventory level."}, "count_distinct_customers": {"type": "bigint", "index": 75, "name": "count_distinct_customers", "comment": "The number of distinct customers (based on customer_id) that have placed orders against this inventory level."}, "count_distinct_customer_emails": {"type": "bigint", "index": 76, "name": "count_distinct_customer_emails", "comment": "The number of distinct customer emails that have placed orders against this inventory level."}, "first_order_timestamp": {"type": "timestamp without time zone", "index": 77, "name": "first_order_timestamp", "comment": "The timetamp of the first order against this inventory level."}, "last_order_timestamp": {"type": "timestamp without time zone", "index": 78, "name": "last_order_timestamp", "comment": "The timestamp of the first order against this inventory level."}, "subtotal_sold_refunds": {"type": "numeric", "index": 79, "name": "subtotal_sold_refunds", "comment": "The monetary amount (in shop currency) of inventory level goods that have been refunded."}, "quantity_sold_refunds": {"type": "numeric", "index": 80, "name": "quantity_sold_refunds", "comment": "The quantity of inventory level goods that have been refunded."}, "count_fulfillment_pending": {"type": "bigint", "index": 81, "name": "count_fulfillment_pending", "comment": "Count of currently pending distinct fulfillments for this inventory level. \"Pending\" = Shopify has created the fulfillment and is waiting for the third-party fulfillment service to transition it to 'open' or 'success'.\n"}, "count_fulfillment_open": {"type": "bigint", "index": 82, "name": "count_fulfillment_open", "comment": "Count of currently open distinct fulfillments for this inventory level. \"Open\" = The fulfillment has been acknowledged by the service and is in processing.\n"}, "count_fulfillment_success": {"type": "bigint", "index": 83, "name": "count_fulfillment_success", "comment": "Count of successful distinct fulfillments for this inventory level. \"Success\" = The fulfillment was successful.\n"}, "count_fulfillment_cancelled": {"type": "bigint", "index": 84, "name": "count_fulfillment_cancelled", "comment": "Count of cancelled distinct fulfillments for this inventory level. \"Cancelled\" = The fulfillment was cancelled.\n"}, "count_fulfillment_error": {"type": "bigint", "index": 85, "name": "count_fulfillment_error", "comment": "Count of distinct fulfillments for this inventory level that encountered an error. \"Error\" = There was an error with the fulfillment request.\n"}, "count_fulfillment_failure": {"type": "bigint", "index": 86, "name": "count_fulfillment_failure", "comment": "Count of distinct fulfillments for this inventory level that failed. \"Failure\" = The fulfillment request failed.\n"}, "incoming_quantity": {"type": "bigint", "index": 87, "name": "incoming_quantity", "comment": "The incoming quantity on its way to a merchant's location. Returns null if the inventory item is not tracked."}, "on_hand_quantity": {"type": "bigint", "index": 88, "name": "on_hand_quantity", "comment": "The total number of units that are physically at a location. The `on_hand` state equals the sum of inventory quantities that  are in the `available`, `committed`, `reserved`, `damaged`, `safety_stock`, and `quality_control` states. Returns null if the inventory item is not tracked.\n"}, "available_quantity": {"type": "bigint", "index": 89, "name": "available_quantity", "comment": "The available quantity that a merchant can sell, determined by coalescing the `quantity` where  inventory_state_name = 'available' from `stg_shopify__inventory_quantity`and `available_quantity`  from the deprecated `stg_shopify__inventory_level`. Returns null if the inventory item is not tracked.\n"}, "committed_quantity": {"type": "bigint", "index": 90, "name": "committed_quantity", "comment": "The number of units that are part of a placed order but aren't fulfilled. When a draft order is created, the inventory isn't committed until the draft order is completed and an order is created. Returns null if the inventory item is not tracked."}, "reserved_quantity": {"type": "bigint", "index": 91, "name": "reserved_quantity", "comment": "The on-hand units that are temporarily set aside. Returns null if the inventory item is not tracked."}, "damaged_quantity": {"type": "bigint", "index": 92, "name": "damaged_quantity", "comment": "The on-hand units that aren't sellable or usable due to damage. Returns null if the inventory item is not tracked."}, "safety_stock_quantity": {"type": "bigint", "index": 93, "name": "safety_stock_quantity", "comment": "The on-hand units that are set aside to help guard against overselling. Returns null if the inventory item is not tracked."}, "quality_control_quantity": {"type": "bigint", "index": 94, "name": "quality_control_quantity", "comment": "The on-hand units that aren't sellable because they're currently in inspection for quality purposes. Returns null if the inventory item is not tracked."}, "net_subtotal_sold": {"type": "numeric", "index": 95, "name": "net_subtotal_sold", "comment": "Net monetary amount sold (in shop currency) from the inventory level. Excludes refunds."}, "net_quantity_sold": {"type": "numeric", "index": 96, "name": "net_quantity_sold", "comment": "Net quantity sold from this inventory level. Excludes refunds."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify__inventory_levels"}, "model.shopify.shopify__line_item_enhanced": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify__line_item_enhanced", "database": "postgres", "comment": "This model constructs a comprehensive, denormalized analytical table that enables reporting on key revenue, customer, and product metrics from your billing platform. It\u2019s designed to align with the schema of the `*__line_item_enhanced` model found in Shopify, Recharge, Stripe, Zuora, and Recurly, offering standardized reporting across various billing platforms. To see the kinds of insights this model can generate, explore example visualizations in the [Fivetran Billing Model Streamlit App](https://fivetran-billing-model.streamlit.app/). Visit the app for more details.", "owner": "postgres"}, "columns": {"header_id": {"type": "bigint", "index": 1, "name": "header_id", "comment": "Id of corresponding order."}, "line_item_id": {"type": "numeric(28,6)", "index": 2, "name": "line_item_id", "comment": "Order line item id."}, "line_item_index": {"type": "numeric(28,6)", "index": 3, "name": "line_item_index", "comment": "Unique index of each line item id for each order."}, "record_type": {"type": "text", "index": 4, "name": "record_type", "comment": "header or line_item"}, "created_at": {"type": "timestamp without time zone", "index": 5, "name": "created_at", "comment": "When the order was created"}, "currency": {"type": "text", "index": 6, "name": "currency", "comment": "Currency used in the order."}, "header_status": {"type": "text", "index": 7, "name": "header_status", "comment": "Status of the order."}, "product_id": {"type": "numeric(28,6)", "index": 8, "name": "product_id", "comment": "Product ID"}, "product_name": {"type": "text", "index": 9, "name": "product_name", "comment": "Product name"}, "transaction_type": {"type": "text", "index": 10, "name": "transaction_type", "comment": "Transaction type (Charge, Refund, etc)"}, "billing_type": {"type": "text", "index": 11, "name": "billing_type", "comment": "NA for Shopify."}, "product_type": {"type": "text", "index": 12, "name": "product_type", "comment": "Product type"}, "quantity": {"type": "numeric(28,6)", "index": 13, "name": "quantity", "comment": "The number of units of this line item."}, "unit_amount": {"type": "numeric(28,6)", "index": 14, "name": "unit_amount", "comment": "Amount per unit, or the price."}, "discount_amount": {"type": "double precision", "index": 15, "name": "discount_amount", "comment": "The discount amount associated with this order."}, "tax_amount": {"type": "double precision", "index": 16, "name": "tax_amount", "comment": "The tax amount associated with this order."}, "total_amount": {"type": "numeric(28,6)", "index": 17, "name": "total_amount", "comment": "Order total"}, "payment_id": {"type": "text", "index": 18, "name": "payment_id", "comment": "Transaction ID"}, "payment_method_id": {"type": "text", "index": 19, "name": "payment_method_id", "comment": "Shopify does not have a particular payment_method_id, therefore all records will be null."}, "payment_method": {"type": "text", "index": 20, "name": "payment_method", "comment": "Transaction gateway for Shopify ('gift card', 'shopify payments', etc)"}, "payment_at": {"type": "text", "index": 21, "name": "payment_at", "comment": "Transaction processed timestamp"}, "fee_amount": {"type": "double precision", "index": 22, "name": "fee_amount", "comment": "The total shipping fee associated with the order."}, "refund_amount": {"type": "double precision", "index": 23, "name": "refund_amount", "comment": "Refund amount associated with this order."}, "subscription_id": {"type": "text", "index": 24, "name": "subscription_id", "comment": "Shopify does not include subscriptions, therefore all records will be null."}, "subscription_plan": {"type": "text", "index": 25, "name": "subscription_plan", "comment": "Shopify does not include subscriptions, therefore all records will be null."}, "subscription_period_started_at": {"type": "timestamp without time zone", "index": 26, "name": "subscription_period_started_at", "comment": "Shopify does not include subscriptions, therefore all records will be null."}, "subscription_period_ended_at": {"type": "timestamp without time zone", "index": 27, "name": "subscription_period_ended_at", "comment": "Shopify does not include subscriptions, therefore all records will be null."}, "subscription_status": {"type": "text", "index": 28, "name": "subscription_status", "comment": "Shopify does not include subscriptions, therefore all records will be null."}, "customer_id": {"type": "bigint", "index": 29, "name": "customer_id", "comment": "Customer associated with this order."}, "customer_created_at": {"type": "timestamp without time zone", "index": 30, "name": "customer_created_at", "comment": "The date and time when the customer was created."}, "customer_level": {"type": "text", "index": 31, "name": "customer_level", "comment": "Whether 'account' or 'customer'. For Shopify, the level is 'customer'."}, "customer_name": {"type": "text", "index": 32, "name": "customer_name", "comment": "Customer name"}, "customer_company": {"type": "text", "index": 33, "name": "customer_company", "comment": "Associated customer's company noted on the shipping address if applicable."}, "customer_email": {"type": "text", "index": 34, "name": "customer_email", "comment": "Customer email"}, "customer_city": {"type": "text", "index": 35, "name": "customer_city", "comment": "Customer's shipping address city"}, "customer_country": {"type": "text", "index": 36, "name": "customer_country", "comment": "Customer's shipping address country"}, "source_relation": {"type": "text", "index": 37, "name": "source_relation", "comment": "The source of the record if the unioning functionality is being used. If not this field will be empty."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify__line_item_enhanced"}, "model.shopify.shopify__order_lines": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify__order_lines", "database": "postgres", "comment": "Each record represents a line item of an order in Shopify.", "owner": "postgres"}, "columns": {"order_line_id": {"type": "bigint", "index": 1, "name": "order_line_id", "comment": "The ID of the line item."}, "index": {"type": "integer", "index": 2, "name": "index", "comment": "The index associated with the order."}, "name": {"type": "text", "index": 3, "name": "name", "comment": "The name of the product variant."}, "order_id": {"type": "bigint", "index": 4, "name": "order_id", "comment": "The ID of the related order."}, "fulfillable_quantity": {"type": "integer", "index": 5, "name": "fulfillable_quantity", "comment": "The amount available to fulfill, calculated as follows: quantity - max(refunded_quantity, fulfilled_quantity) - pending_fulfilled_quantity - open_fulfilled_quantity\n"}, "fulfillment_status": {"type": "text", "index": 6, "name": "fulfillment_status", "comment": "How far along an order is in terms line items fulfilled."}, "is_gift_card": {"type": "boolean", "index": 7, "name": "is_gift_card", "comment": "Whether the item is a gift card. If true, then the item is not taxed or considered for shipping charges."}, "grams": {"type": "integer", "index": 8, "name": "grams", "comment": "The weight of the item in grams."}, "pre_tax_price": {"type": "integer", "index": 9, "name": "pre_tax_price", "comment": "The total pre tax price of the order."}, "pre_tax_price_set": {"type": "text", "index": 10, "name": "pre_tax_price_set", "comment": "The pre tax price of the line item in shop currency and presentment currency."}, "price": {"type": "double precision", "index": 11, "name": "price", "comment": "The price of the item before discounts have been applied in the shop currency."}, "price_set": {"type": "text", "index": 12, "name": "price_set", "comment": "The price of the line item in shop and presentment currencies."}, "product_id": {"type": "bigint", "index": 13, "name": "product_id", "comment": "The ID of the product that the line item belongs to. Can be null if the original product associated with the order is deleted at a later date."}, "quantity": {"type": "integer", "index": 14, "name": "quantity", "comment": "The number of items that were purchased."}, "is_shipping_required": {"type": "boolean", "index": 15, "name": "is_shipping_required", "comment": "Whether the item requires shipping."}, "sku": {"type": "text", "index": 16, "name": "sku", "comment": "The item's SKU (stock keeping unit)."}, "is_taxable": {"type": "boolean", "index": 17, "name": "is_taxable", "comment": "Whether the item was taxable."}, "tax_code": {"type": "text", "index": 18, "name": "tax_code", "comment": "This parameter applies only to the stores that have the Avalara AvaTax app installed. Sp