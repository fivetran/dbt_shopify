o oldest. - `manual`: The products are manually sorted by the shop owner. - `price-asc`: The products are sorted by price from lowest to highest. - `price-desc`: The products are sorted by price from highest to lowest.\n"}, "title": {"type": "text", "index": 8, "name": "title", "comment": "The name of the collection"}, "published_at": {"type": "timestamp without time zone", "index": 9, "name": "published_at", "comment": "The time and date (ISO 8601 format) when the collection was made visible. Returns null for a hidden collection."}, "updated_at": {"type": "timestamp without time zone", "index": 10, "name": "updated_at", "comment": "The date and time (ISO 8601 format) when the collection was last modified."}, "_fivetran_synced": {"type": "timestamp without time zone", "index": 11, "name": "_fivetran_synced", "comment": "The time when a record was last updated by Fivetran."}, "source_relation": {"type": "text", "index": 12, "name": "source_relation", "comment": "The schema or database this record came from if you are making use of the `shopify_union_schemas` or `shopify_union_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.stg_shopify__collection"}, "model.shopify.stg_shopify__collection_product": {"metadata": {"type": "VIEW", "schema": "public_shopify", "name": "stg_shopify__collection_product", "database": "postgres", "comment": "Table relating products to the collections they belong to. Use this instead of the deprecated `COLLECT` table.", "owner": "postgres"}, "columns": {"collection_id": {"type": "bigint", "index": 1, "name": "collection_id", "comment": "ID referencing the `collection` the product belongs to."}, "product_id": {"type": "bigint", "index": 2, "name": "p