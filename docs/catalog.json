tomer."}, "avg_quantity_per_order": {"type": "numeric", "index": 30, "name": "avg_quantity_per_order", "comment": "Average quantity of items per order customer orders."}, "lifetime_total_tax": {"type": "double precision", "index": 31, "name": "lifetime_total_tax", "comment": "Total amount of tax attributed to the customer."}, "avg_tax_per_order": {"type": "double precision", "index": 32, "name": "avg_tax_per_order", "comment": "Average tax per order attributed to the customer."}, "lifetime_total_discount": {"type": "double precision", "index": 33, "name": "lifetime_total_discount", "comment": "Total discounts attributed to the customer."}, "avg_discount_per_order": {"type": "double precision", "index": 34, "name": "avg_discount_per_order", "comment": "Average discount per order attributed to the customer."}, "lifetime_total_shipping": {"type": "double precision", "index": 35, "name": "lifetime_total_shipping", "comment": "Total shipping costs attributed to the customer."}, "avg_shipping_per_order": {"type": "double precision", "index": 36, "name": "avg_shipping_per_order", "comment": "Average shipping cost per order attributed to the customer."}, "lifetime_total_shipping_with_discounts": {"type": "double precision", "index": 37, "name": "lifetime_total_shipping_with_discounts", "comment": "Total shipping costs after discounts attributed to the customer."}, "avg_shipping_with_discounts_per_order": {"type": "double precision", "index": 38, "name": "avg_shipping_with_discounts_per_order", "comment": "Average shipping costs after discounts per order attributed to the customer."}, "lifetime_total_shipping_tax": {"type": "double precision", "index": 39, "name": "lifetime_total_shipping_tax", "comment": "Total shipping tax attributed to the customer."}, "avg_shipping_tax_per_order": {"type": "double precision", "index": 40, "name": "avg_shipping_tax_per_order", "comment": "Average shipping tax per order attributed to the customer."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify_gql__customers"}, "model.shopify.shopify_gql__daily_shop": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify_gql__daily_shop", "database": "postgres", "comment": "Each record represents a day in your Shop, enriched with a suite of metrics. Will also include `SHOP` metafields if enabled.\n", "owner": "postgres"}, "columns": {"date_day": {"type": "date", "index": 1, "name": "date_day", "comment": "Day for which the shop activity is being measured."}, "shop_id": {"type": "integer", "index": 2, "name": "shop_id", "comment": "The ID for the shop. A 64-bit unsigned integer."}, "name": {"type": "text", "index": 3, "name": "name", "comment": "The name of the shop."}, "domain": {"type": "text", "index": 4, "name": "domain", "comment": "The shop's domain."}, "is_deleted": {"type": "boolean", "index": 5, "name": "is_deleted", "comment": "Boolean representing whether the record was soft-deleted in Shopify."}, "currency": {"type": "text", "index": 6, "name": "currency", "comment": "The three-letter code (ISO 4217 format) for the shop's default currency."}, "enabled_presentment_currencies": {"type": "text", "index": 7, "name": "enabled_presentment_currencies", "comment": "An array of of enabled currencies (ISO 4217 format) that the shop accepts. Merchants can enable currencies from their Shopify Payments settings in the Shopify Admin."}, "iana_timezone": {"type": "text", "index": 8, "name": "iana_timezone", "comment": "The name of the timezone assigned by the [IANA](https://www.iana.org/time-zones)."}, "created_at": {"type": "timestamp without time zone", "index": 9, "name": "created_at", "comment": "The date and time (ISO 8601) when the shop was created."}, "source_relation": {"type": "text", "index": 10, "name": "source_relation", "comment": "The schema or database this record came from if you are making use of the `shopify_union_schemas` or `shopify_union_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}, "metafield_bea81c1795a612d8fc3a232b156467c0_different_field": {"type": "text", "index": 11, "name": "metafield_bea81c1795a612d8fc3a232b156467c0_different_field", "comment": null}, "metafield_bea81c1795a612d8fc3a232b156467c0_gwrgew": {"type": "text", "index": 12, "name": "metafield_bea81c1795a612d8fc3a232b156467c0_gwrgew", "comment": null}, "count_orders": {"type": "bigint", "index": 13, "name": "count_orders", "comment": "Count of the distinct orders placed on this day."}, "count_line_items": {"type": "numeric", "index": 14, "name": "count_line_items", "comment": "Count of the line items included in orders placed on this day."}, "avg_line_item_count": {"type": "numeric", "index": 15, "name": "avg_line_item_count", "comment": "Average line item count for orders placed on this day."}, "count_customers": {"type": "bigint", "index": 16, "name": "count_customers", "comment": "Count of distinct customers who placed an order on this day."}, "count_customer_emails": {"type": "bigint", "index": 17, "name": "count_customer_emails", "comment": "Count of distinct customer email addresses who placed an order on this day."}, "order_adjusted_total": {"type": "double precision", "index": 18, "name": "order_adjusted_total", "comment": "Order total adjusted for refunds and other adjustments. The calculation used for this field is as follows: total price listed on the original order (including shipping costs and discounts) + adjustments + adjustments tax - total refunds - refunds tax The order_adjusted_total will equate to the total sales - refunds listed within the transactions table for the order (after currency exchange).\n"}, "avg_order_value": {"type": "double precision", "index": 19, "name": "avg_order_value", "comment": "Average adjusted total per order placed on this day (in shop currency)."}, "shipping_cost": {"type": "double precision", "index": 20, "name": "shipping_cost", "comment": "The shipping cost of the orders placed on this day (in shop currency)."}, "order_adjustment_amount": {"type": "double precision", "index": 21, "name": "order_adjustment_amount", "comment": "Total adjustment amount (in shop currency) applied to the orders placed on this day."}, "order_adjustment_tax_amount": {"type": "double precision", "index": 22, "name": "order_adjustment_tax_amount", "comment": "Total tax applied to adjustments (in shop currency) on the orders placed on this day."}, "refund_subtotal": {"type": "double precision", "index": 23, "name": "refund_subtotal", "comment": "Total refund amount applied to the orders placed on this day."}, "refund_total_tax": {"type": "double precision", "index": 24, "name": "refund_total_tax", "comment": "Total tax applied to the refund on the orders placed on this day (in shop currency)."}, "total_discounts": {"type": "double precision", "index": 25, "name": "total_discounts", "comment": "The total amount of the discount allocated to this day's orders in the shop's currency."}, "avg_discount": {"type": "double precision", "index": 26, "name": "avg_discount", "comment": "Average total discount placed on orders on this day (in shop currency)."}, "shipping_discount_amount": {"type": "double precision", "index": 27, "name": "shipping_discount_amount", "comment": "The total amount of discount (in shop currency) allocated toward shipping for orders placed on this day."}, "avg_shipping_discount_amount": {"type": "double precision", "index": 28, "name": "avg_shipping_discount_amount", "comment": "Average discount amount (in shop currency) allocated toward shipping on orders placed on this day."}, "percentage_calc_discount_amount": {"type": "double precision", "index": 29, "name": "percentage_calc_discount_amount", "comment": "The total amount of discount (in shop currency) allocated via a percentage-based discount for orders placed on this day."}, "avg_percentage_calc_discount_amount": {"type": "double precision", "index": 30, "name": "avg_percentage_calc_discount_amount", "comment": "Average discount amount (in shop currency) allocated via a percentage-based-discount on orders placed on this day."}, "fixed_amount_discount_amount": {"type": "double precision", "index": 31, "name": "fixed_amount_discount_amount", "comment": "The total amount of discount (in shop currency) allocated via a fixed-amount discount for orders placed on this day."}, "avg_fixed_amount_discount_amount": {"type": "double precision", "index": 32, "name": "avg_fixed_amount_discount_amount", "comment": "Average discount amount (in shop currency) allocated via a fixed-amount-discount on orders placed on this day."}, "count_discount_codes_applied": {"type": "numeric", "index": 33, "name": "count_discount_codes_applied", "comment": "Distinct discount codes applied by customers on orders for this day."}, "count_locations_ordered_from": {"type": "bigint", "index": 34, "name": "count_locations_ordered_from", "comment": "Distinct locations with orders placed against them on this day."}, "count_orders_with_discounts": {"type": "bigint", "index": 35, "name": "count_orders_with_discounts", "comment": "Count of orders in which a discount was applied."}, "count_orders_with_refunds": {"type": "bigint", "index": 36, "name": "count_orders_with_refunds", "comment": "Count of orders in which there was a refund."}, "first_order_timestamp": {"type": "timestamp without time zone", "index": 37, "name": "first_order_timestamp", "comment": "Timestamp of the first order of the day for the shop."}, "last_order_timestamp": {"type": "timestamp without time zone", "index": 38, "name": "last_order_timestamp", "comment": "Timestamp of the last order of the day for the shop."}, "quantity_sold": {"type": "bigint", "index": 39, "name": "quantity_sold", "comment": "Total quantity sold from the inventory level. Includes refunds."}, "quantity_refunded": {"type": "double precision", "index": 40, "name": "quantity_refunded", "comment": "The quantity of goods ORDERED on this day that have been refunded."}, "quantity_net": {"type": "double precision", "index": 41, "name": "quantity_net", "comment": "Net quantity sold from this shop on this day. Excludes refunds."}, "avg_quantity_sold": {"type": "bigint", "index": 42, "name": "avg_quantity_sold", "comment": "Average quantity sold per order on this day. Includes refunds. (in shop currency)"}, "avg_quantity_net": {"type": "double precision", "index": 43, "name": "avg_quantity_net", "comment": "Average net quantity sold per order on this day. Excludes refunds. (in shop currency)"}, "count_variants_sold": {"type": "bigint", "index": 44, "name": "count_variants_sold", "comment": "Distinct product variants sold on this day (includes refunds)."}, "count_products_sold": {"type": "bigint", "index": 45, "name": "count_products_sold", "comment": "Distinct products sold on this day (includes refunds)."}, "quantity_gift_cards_sold": {"type": "double precision", "index": 46, "name": "quantity_gift_cards_sold", "comment": "Quantity of gift cards sold on this day."}, "quantity_requiring_shipping": {"type": "double precision", "index": 47, "name": "quantity_requiring_shipping", "comment": "Quantity of goods sold on this day that require shipping."}, "count_abandoned_checkouts": {"type": "bigint", "index": 48, "name": "count_abandoned_checkouts", "comment": "Count of abandoned checkouts on this day."}, "count_customers_abandoned_checkout": {"type": "bigint", "index": 49, "name": "count_customers_abandoned_checkout", "comment": "Count of distinct customers who abandoned checkouts on this day."}, "count_customer_emails_abandoned_checkout": {"type": "bigint", "index": 50, "name": "count_customer_emails_abandoned_checkout", "comment": "Count of distinct customer emails who abandoned checkouts on this day."}, "count_fulfillment_attempted_delivery": {"type": "bigint", "index": 51, "name": "count_fulfillment_attempted_delivery", "comment": "Count of distinct fulfillments on this day where the delivery of the shipment was attempted, but unable to be completed."}, "count_fulfillment_delayed": {"type": "bigint", "index": 52, "name": "count_fulfillment_delayed", "comment": "Count of delayed distinct fulfillments."}, "count_fulfillment_delivered": {"type": "bigint", "index": 53, "name": "count_fulfillment_delivered", "comment": "Count of successful distinct fulfillments successfully delivered on this day."}, "count_fulfillment_failure": {"type": "bigint", "index": 54, "name": "count_fulfillment_failure", "comment": "Count of failed distinct fulfillments on this day. Something went wrong when pulling tracking information for the shipment, such as the tracking number was invalid or the shipment was canceled."}, "count_fulfillment_in_transit": {"type": "bigint", "index": 55, "name": "count_fulfillment_in_transit", "comment": "Count of distinct fulfillments in transit on this day. Each shipment is being transported between shipping facilities on the way to its destination."}, "count_fulfillment_out_for_delivery": {"type": "bigint", "index": 56, "name": "count_fulfillment_out_for_delivery", "comment": "Count of distinct fulfillments being delivered to their final destination."}, "count_fulfillment_ready_for_pickup": {"type": "bigint", "index": 57, "name": "count_fulfillment_ready_for_pickup", "comment": "Count of distinct fulfillments ready for pickup at a shipping depot."}, "count_fulfillment_label_printed": {"type": "bigint", "index": 58, "name": "count_fulfillment_label_printed", "comment": "Count of distinct fulfillments for which a purchased shipping label has been printed on this day."}, "count_fulfillment_label_purchased": {"type": "bigint", "index": 59, "name": "count_fulfillment_label_purchased", "comment": "Count of distinct fulfillments for which a shipping label has been purchased (but not printed yet) on this day."}, "count_fulfillment_confirmed": {"type": "bigint", "index": 60, "name": "count_fulfillment_confirmed", "comment": "Count of confirmed distinct fulfillments. This is the default status when no other information is available about a fulfillment."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify_gql__daily_shop"}, "model.shopify.shopify_gql__discounts": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify_gql__discounts", "database": "postgres", "comment": "Each record represents a unique discount, enriched with discount metadata and metrics regarding orders and abandoned checkouts.\n", "owner": "postgres"}, "columns": {"source_relation": {"type": "text", "index": 1, "name": "source_relation", "comment": "The schema or database this record came from if you are making use of the `shopify_union_schemas` or `shopify_union_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}, "discount_code_id": {"type": "integer", "index": 2, "name": "discount_code_id", "comment": "The ID for the discount code."}, "discount_type": {"type": "text", "index": 3, "name": "discount_type", "comment": "The type of discount (e.g. 'basic', 'bxgy', 'free_shipping', 'app')."}, "applies_once_per_customer": {"type": "boolean", "index": 4, "name": "applies_once_per_customer", "comment": "Whether the discount can be used only once per customer."}, "usage_count": {"type": "integer", "index": 5, "name": "usage_count", "comment": "Number of times the discount has been used (asynchronously updated)."}, "codes_count": {"type": "integer", "index": 6, "name": "codes_count", "comment": "Number of unique redeem codes associated with the discount."}, "codes_precision": {"type": "text", "index": 7, "name": "codes_precision", "comment": "Indicates whether `codes_count` is exact or estimated."}, "combines_with_order_discounts": {"type": "boolean", "index": 8, "name": "combines_with_order_discounts", "comment": "Whether this discount can be combined with order-level discounts."}, "combines_with_product_discounts": {"type": "boolean", "index": 9, "name": "combines_with_product_discounts", "comment": "Whether this discount can be combined with product-level discounts."}, "combines_with_shipping_discounts": {"type": "boolean", "index": 10, "name": "combines_with_shipping_discounts", "comment": "Whether this discount can be combined with shipping-level discounts."}, "created_at": {"type": "timestamp without time zone", "index": 11, "name": "created_at", "comment": "Timestamp when the discount was created."}, "customer_selection_all_customers": {"type": "boolean", "index": 12, "name": "customer_selection_all_customers", "comment": "Whether the discount is available to all customers."}, "ends_at": {"type": "timestamp without time zone", "index": 13, "name": "ends_at", "comment": "Timestamp when the discount ends or expires."}, "starts_at": {"type": "timestamp without time zone", "index": 14, "name": "starts_at", "comment": "Timestamp when the discount becomes active."}, "status": {"type": "text", "index": 15, "name": "status", "comment": "Current status of the discount (e.g. 'active', 'expired', 'scheduled')."}, "title": {"type": "text", "index": 16, "name": "title", "comment": "The discount\u2019s display name in the Shopify admin and to customers."}, "total_sales_amount": {"type": "double precision", "index": 17, "name": "total_sales_amount", "comment": "The total sales amount that resulted from the usage of this discount."}, "total_sales_currency_code": {"type": "text", "index": 18, "name": "total_sales_currency_code", "comment": "The currency code associated with `total_sales_amount`."}, "updated_at": {"type": "timestamp without time zone", "index": 19, "name": "updated_at", "comment": "Timestamp when the discount was last updated."}, "usage_limit": {"type": "integer", "index": 20, "name": "usage_limit", "comment": "The total number of times the discount code can be used."}, "code": {"type": "text", "index": 21, "name": "code", "comment": "The case-insensitive discount code that customers use at checkout."}, "allocation_method": {"type": "text", "index": 22, "name": "allocation_method", "comment": "The method by which the discount is allocated. Valid values include `each` (applies the discount to each eligible item) and `across` (spreads the discount value across eligible items).\n"}, "target_selection": {"type": "text", "index": 23, "name": "target_selection", "comment": "Indicates whether the discount applies to 'all' or 'entitled' items."}, "target_type": {"type": "text", "index": 24, "name": "target_type", "comment": "The type of target this discount applies to (e.g., `line_item` or `shipping_line`)."}, "value_amount": {"type": "double precision", "index": 25, "name": "value_amount", "comment": "The numerical value of the discount application. A monetary value in decimal format, allowing for precise representation of cents or fractional currency."}, "value_currency_code": {"type": "text", "index": 26, "name": "value_currency_code", "comment": "The three-letter currency code for the discount that represents a world currency used in a store."}, "value_percentage": {"type": "double precision", "index": 27, "name": "value_percentage", "comment": "The percentage discount value that is applied to a line, a number ranging between -100 (free) and 0 (no discount)\n"}, "value_type": {"type": "text", "index": 28, "name": "value_type", "comment": "How the discount value is interpreted (e.g., 'percentage', 'fixed_amount')."}, "unique_key": {"type": "text", "index": 29, "name": "unique_key", "comment": "Unique key representing a discount.\nHashed on 'source_relation', 'discount_code_id', 'discount_id', 'discount_type',\n'code', 'allocation_method', 'target_selection', 'target_type', 'value_amount',\n'value_currency_code', 'value_percentage', 'value_type'.\n"}, "count_orders": {"type": "bigint", "index": 30, "name": "count_orders", "comment": "Count of orders in which this discount code was applied."}, "avg_order_discount_amount": {"type": "double precision", "index": 31, "name": "avg_order_discount_amount", "comment": "Average amount (in shop currency) of discount taken off orders."}, "total_order_discount_amount": {"type": "double precision", "index": 32, "name": "total_order_discount_amount", "comment": "Total monetary amount (in shop currency) of discounts taken off of orders."}, "total_order_line_items_price": {"type": "double precision", "index": 33, "name": "total_order_line_items_price", "comment": "Total monetary amount (in shop currency) of line items for orders that have used this discount."}, "total_order_shipping_cost": {"type": "double precision", "index": 34, "name": "total_order_shipping_cost", "comment": "Total shipping costs for orders that used this discount."}, "total_order_refund_amount": {"type": "double precision", "index": 35, "name": "total_order_refund_amount", "comment": "Total refunded amount (in shop currency) for orders that used this discount code."}, "count_customers": {"type": "bigint", "index": 36, "name": "count_customers", "comment": "Count of distinct customers who placed orders using this discount."}, "count_customer_emails": {"type": "bigint", "index": 37, "name": "count_customer_emails", "comment": "Count of distinct customer emails who placed orders using this discount."}, "total_abandoned_checkout_discount_amount": {"type": "double precision", "index": 38, "name": "total_abandoned_checkout_discount_amount", "comment": "Total monetary amount (in shop currency) of discounts taken off abandoned checkout orders."}, "count_abandoned_checkouts": {"type": "bigint", "index": 39, "name": "count_abandoned_checkouts", "comment": "Count of abandoned checkouts in which this discount code was applied."}, "count_abandoned_checkout_customers": {"type": "bigint", "index": 40, "name": "count_abandoned_checkout_customers", "comment": "Distinct count of customers who applied this discount in a checkout that they abandoned."}, "count_abandoned_checkout_customer_emails": {"type": "bigint", "index": 41, "name": "count_abandoned_checkout_customer_emails", "comment": "Distinct count of customer emails who applied this discount in a checkout that they abandoned."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify_gql__discounts"}, "model.shopify.shopify_gql__inventory_levels": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify_gql__inventory_levels", "database": "postgres", "comment": "Model representing the current status of an inventory level in Shopify. Inventory Levels are unique pairings of  inventory items (which have a 1:1 relationship with product variants) and locations. \nInventory Level = Inventory item @ a Location.\nWill also include `PRODUCT_VARIANT` metafields if enabled.\n", "owner": "postgres"}, "columns": {"inventory_level_id": {"type": "integer", "index": 1, "name": "inventory_level_id", "comment": "A globally unique identifier for the inventory level."}, "inventory_item_id": {"type": "integer", "index": 2, "name": "inventory_item_id", "comment": "The ID of the inventory item associated with the inventory level."}, "location_id": {"type": "integer", "index": 3, "name": "location_id", "comment": "The ID of the location that the inventory level belongs to."}, "can_deactivate": {"type": "boolean", "index": 4, "name": "can_deactivate", "comment": "Indicates whether the inventory item can be deactivated at the location."}, "deactivation_alert": {"type": "text", "index": 5, "name": "deactivation_alert", "comment": "Provides an alert message when the inventory item is deactivated at 