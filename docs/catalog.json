es. This is different from the order_number property, which is the ID used by the shop owner and customer."}, "user_id": {"type": "bigint", "index": 2, "name": "user_id", "comment": "The ID of the user logged into Shopify POS who processed the order, if applicable."}, "total_discounts": {"type": "double precision", "index": 3, "name": "total_discounts", "comment": "The total discounts applied to the price of the order in the shop currency."}, "total_discounts_set": {"type": "text", "index": 4, "name": "total_discounts_set", "comment": "The total discounts applied to the price of the order in shop and presentment currencies."}, "total_line_items_price": {"type": "double precision", "index": 5, "name": "total_line_items_price", "comment": "The sum of all line item prices in the shop currency."}, "total_line_items_price_set": {"type": "text", "index": 6, "name": "total_line_items_price_set", "comment": "The total of all line item prices in shop and presentment currencies."}, "total_price": {"type": "double precision", "index": 7, "name": "total_price", "comment": "The sum of all line item prices, discounts, shipping, taxes, and tips in the shop currency. Must be positive."}, "total_price_set": {"type": "text", "index": 8, "name": "total_price_set", "comment": "The total price of the order in shop and presentment currencies."}, "total_tax_set": {"type": "text", "index": 9, "name": "total_tax_set", "comment": "The total tax applied to the order in shop and presentment currencies."}, "total_tax": {"type": "double precision", "index": 10, "name": "total_tax", "comment": "The sum of all the taxes applied to the order in th shop currency. Must be positive."}, "source_name": {"type": "text", "index": 11, "name": "source_name", "comment": "Where the order originated. Can be set only during order creation, and is not writeable afterwards."}, "subtotal_price": {"type": "double precision", "index": 12, "name": "subtotal_price", "comment": "The price of the order in the shop currency after discounts but before shipping, taxes, and tips."}, "has_taxes_included": {"type": "boolean", "index": 13, "name": "has_taxes_included", "comment": "Whether taxes are included in the order subtotal."}, "total_weight": {"type": "integer", "index": 14, "name": "total_weight", "comment": "The sum of all line item weights in grams."}, "total_tip_received": {"type": "double precision", "index": 15, "name": "total_tip_received", "comment": "The sum of all the tips in the order in the shop currency."}, "landing_site_base_url": {"type": "text", "index": 16, "name": "landing_site_base_url", "comment": "The URL for the page where the buyer landed when they entered the shop."}, "location_id": {"type": "bigint", "index": 17, "name": "location_id", "comment": "The ID of the physical location where the order was processed."}, "name": {"type": "text", "index": 18, "name": "name", "comment": "The order name, generated by combining the order_number property with the order prefix and suffix that are set in the merchant's general settings."}, "note": {"type": "text", "index": 19, "name": "note", "comment": "An optional note that a shop owner can attach to the order."}, "number": {"type": "integer", "index": 20, "name": "number", "comment": "The order's position in the shop's count of orders. Numbers are sequential and start at 1."}, "order_number": {"type": "integer", "index": 21, "name": "order_number", "comment": "The order 's position in the shop's count of orders starting at 1001. Order numbers are sequential and start at 1001."}, "cancel_reason": {"type": "integer", "index": 22, "name": "cancel_reason", "comment": "The reason why the order was canceled."}, "cart_token": {"type": "text", "index": 23, "name": "cart_token", "comment": "The ID of the cart that's associated with the order."}, "checkout_token": {"type": "text", "index": 24, "name": "checkout_token", "comment": "The checkout token applied to the order."}, "created_timestamp": {"type": "timestamp without time zo