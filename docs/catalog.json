 "created_at", "comment": "When the order was created"}, "currency": {"type": "text", "index": 6, "name": "currency", "comment": "Currency used in the order."}, "header_status": {"type": "text", "index": 7, "name": "header_status", "comment": "Status of the order."}, "product_id": {"type": "numeric(28,6)", "index": 8, "name": "product_id", "comment": "Product ID"}, "product_name": {"type": "text", "index": 9, "name": "product_name", "comment": "Product name"}, "transaction_type": {"type": "text", "index": 10, "name": "transaction_type", "comment": "Transaction type (Charge, Refund, etc)"}, "billing_type": {"type": "text", "index": 11, "name": "billing_type", "comment": "NA for Shopify."}, "product_type": {"type": "text", "index": 12, "name": "product_type", "comment": "Product type"}, "quantity": {"type": "numeric(28,6)", "index": 13, "name": "quantity", "comment": "The number of units of this line item."}, "unit_amount": {"type": "numeric(28,6)", "index": 14, "name": "unit_amount", "comment": "Amount per unit, or the price."}, "discount_amount": {"type": "double precision", "index": 15, "name": "discount_amount", "comment": "The discount amount associated with this order."}, "tax_amount": {"type": "double precision", "index": 16, "name": "tax_amount", "comment": "The tax amount associated with this order."}, "total_amount": {"type": "numeric(28,6)", "index": 17, "name": "total_amount", "comment": "Order total"}, "payment_id": {"type": "text", "index": 18, "name": "payment_id", "comment": "Transaction ID"}, "payment_method_id": {"type": "text", "index": 19, "name": "payment_method_id", "comment": "Shopify does not have a particular payment_method_id, therefore all records will be null."}, "payment_method": {"type": "text", "index": 20, "name": "payment_method", "comment": "Transaction gateway for Shopify ('gift card', 'shopify payments', etc)"}, "payment_at": {"type": "text", "index": 21, "name": "payment_at", "comment": "Transaction processed timestamp"}, "fee_amou