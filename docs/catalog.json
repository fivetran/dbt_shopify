ame": "quantity_refunded", "comment": "The quantity of goods ORDERED on this day that have been refunded."}, "quantity_net": {"type": "double precision", "index": 41, "name": "quantity_net", "comment": "Net quantity sold from this shop on this day. Excludes refunds."}, "avg_quantity_sold": {"type": "bigint", "index": 42, "name": "avg_quantity_sold", "comment": "Average quantity sold per order on this day. Includes refunds. (in shop currency)"}, "avg_quantity_net": {"type": "double precision", "index": 43, "name": "avg_quantity_net", "comment": "Average net quantity sold per order on this day. Excludes refunds. (in shop currency)"}, "count_variants_sold": {"type": "bigint", "index": 44, "name": "count_variants_sold", "comment": "Distinct product variants sold on this day (includes refunds)."}, "count_products_sold": {"type": "bigint", "index": 45, "name": "count_products_sold", "comment": "Distinct products sold on this day (includes refunds)."}, "quantity_gift_cards_sold": {"type": "double precision", "index": 46, "name": "quantity_gift_cards_sold", "comment": "Quantity of gift cards sold on this day."}, "quantity_requiring_shipping": {"type": "double precision", "index": 47, "name": "quantity_requiring_shipping", "comment": "Quantity of goods sold on this day that require shipping."}, "gross_sales": {"type": "double precision", "index": 48, "name": "gross_sales", "comment": "The total revenue from sales before discounts and returns are applied for this day (in shop currency)."}, "discounts": {"type": "double precision", "index": 49, "name": "discounts", "comment": "The total amount of discounts applied to orders on this day (in shop currency)."}, "returns": {"type": "double precision", "index": 50, "name": "returns", "comment": "The total value of goods returned on orders on this day (in shop currency)."}, "net_sales": {"type": "double precision", "index": 51, "name": "net_sales", "comment": "The net revenue from orders on this day after discounts and returns (gross_sales - discounts - returns, in shop currency)."}, "count_abandoned_checkouts": {"type": "bigint", "index": 52, "name": "count_abandoned_checkouts", "comment": "Count of abandoned checkouts on this day."}, "count_customers_abandoned_checkout": {"type": "bigint", "index": 53, "name": "count_customers_abandoned_checkout", "comment": "Count of distinct customers who abandoned checkouts on this day."}, "count_customer_emails_abandoned_checkout": {"type": "bigint", "index": 54, "name": "count_customer_emails_abandoned_checkout", "comment": "Count of distinct customer emails who abandoned checkouts on this day."}, "count_fulfillment_attempted_delivery": {"type": "bigint", "index": 55, "name": "count_fulfillment_attempted_delivery", "comment": "Count of distinct fulfillments on this day where the delivery of the shipment was attempted, but unable to be completed."}, "count_fulfillment_delayed": {"type": "bigint", "index": 56, "name": "count_fulfillment_delayed", "comment": "Count of delayed distinct fulfillments."}, "count_fulfillment_delivered": {"type": "bigint", "index": 57, "name": "count_fulfillment_delivered", "comment": "Count of successful distinct fulfillments successfully delivered on this day."}, "count_fulfillment_failure": {"type": "bigint", "index": 58, "name": "count_fulfillment_failure", "comment": "Count of failed distinct fulfillments on this day. Something went wrong when pulling tracking information for the shipment, such as the tracking number was invalid or the shipment was canceled."}, "count_fulfillment_in_transit": {"type": "bigint", "index": 59, "name": "count_fulfillment_in_transit", "comment": "Count of distinct fulfillments in transit on this day. Each shipment is being transported between shipping facilities on the way to its destination."}, "count_fulfillment_out_for_delivery": {"type": "bigint", "index": 60, "name": "count_fulfillment_out_for_delivery", "comment": "Count of distinct fulfillments being delivered to their final destination."}, "count_fulfillment_ready_for_pickup": {"type": "bigint", "index": 61, "name": "count_fulfillment_ready_for_pickup", "comment": "Count of distinct fulfillments ready for pickup at a shipping depot."}, "count_fulfillment_label_printed": {"type": "bigint", "index": 62, "name": "count_fulfillment_label_printed", "comment": "Count of distinct fulfillments for which a purchased shipping label has been printed on this day."}, "count_fulfillment_label_purchased": {"type": "bigint", "index": 63, "name": "count_fulfillment_label_purchased", "comment": "Count of distinct fulfillments for which a shipping label has been purchased (but not printed yet) on this day."}, "count_fulfillment_confirmed": {"type": "bigint", "index": 64, "name": "count_fulfillment_confirmed", "comment": "Count of confirmed distinct fulfillments. This is the default status when no other information is available about a fulfillment."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify_gql__daily_shop"}, "model.shopify.shopify_gql__discounts": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify_gql__discounts", "database": "postgres", "comment": "Each record represents a unique discount, enriched with discount metadata and metrics regarding orders and abandoned checkouts.\n", "owner": "postgres"}, "columns": {"source_relation": {"type": "text", "index": 1, "name": "source_relation", "comment": "The schema or database this record came from if you are making use of the `shopify_union_schemas` or `shopify_union_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}, "discount_code_id": {"type": "integer", "index": 2, "name": "discount_code_id", "comment": "The ID for the discount code."}, "discount_type": {"type": "text", "index": 3, "name": "discount_type", "comment": "The type of discount (e.g. 'basic', 'bxgy', 'free_shipping', 'app')."}, "applies_once_per_customer": {"type": "boolean", "index": 4, "name": "applies_once_per_customer", "comment": "Whether the discount can be used only once per customer."}, "usage_count": {"type": "integer", "index": 5, "name": "usage_count", "comment": "Number of times the discount has been used (asynchronously updated)."}, "codes_count": {"type": "integer", "index": 6, "name": "codes_count", "comment": "Number of unique redeem codes associated with the discount."}, "codes_precision": {"type": "text", "index": 7, "name": "codes_precision", "comment": "Indicates whether `codes_count` is exact or estimated."}, "combines_with_order_discounts": {"type": "boolean", "index": 8, "name": "combines_with_order_discounts", "comment": "Whether this discount can be combined with order-level discounts."}, "combines_with_product_discounts": {"type": "boolean", "index": 9, "name": "combines_with_product_discounts", "comment": "Whether this discount can be combined with product-level discounts."}, "combines_with_shipping_discounts": {"type": "boolean", "index": 10, "name": "combines_with_shipping_discounts", "comment": "Whether this discount can be combined with shipping-level discounts."}, "created_at": {"type": "timestamp without time zone", "index": 11, "name": "created_at", "comment": "Timestamp when the discount was created."}, "customer_selection_all_customers": {"type": "boolean", "index": 12, "name": "customer_selection_all_customers", "comment": "Whether the discount is available to all customers."}, "ends_at": {"type": "timestamp without time zone", "index": 13, "name": "ends_at", "comment": "Timestamp when the discount ends or expires."}, "starts_at": {"type": "timestamp without time zone", "index": 14, "name": "starts_at", "comment": "Timestamp when the discount becomes active."}, "status": {"type": "text", "index": 15, "name": "status", "comment": "Current status of the discount (e.g. 'active', 'expired', 'scheduled')."}, "title": {"type": "text", "index": 16, "name": "title", "comment": "The discount\u2019s display name in the Shopify admin and to customers."}, "total_sales_amount": {"type": "double precision", "index": 17, "name": "total_sales_amount", "comment": "The total sales amount that resulted from the usage of this discount."}, "total_sales_currency_code": {"type": "text", "index": 18, "name": "total_sales_currency_code", "comment": "The currency code associated with `total_sales_amount`."}, "updated_at": {"type": "timestamp without time zone", "index": 19, "name": "updated_at", "comment": "Timestamp when the discount was last updated."}, "usage_limit": {"type": "integer", "index": 20, "name": "usage_limit", "comment": "The total number of times the discount code can be used."}, "code": {"type": "text", "index": 21, "name": "code", "comment": "The case-insensitive discount code that customers use at checkout."}, "allocation_method": {"type": "text", "index": 22, "name": "allocation_method", "comment": "The method by which the discount is allocated. Valid values include `each` (applies the discount to each eligible item) and `across` (spreads the discount value across eligible items).\n"}, "target_selection": {"type": "text", "index": 23, "name": "target_selection", "comment": "Indicates whether the discount applies to 'all' or 'entitled' items."}, "target_type": {"type": "text", "index": 24, "name": "target_type", "comment": "The type of target this discount applies to (e.g., `line_item` or `shipping_line`)."}, "value_amount": {"type": "double precision", "index": 25, "name": "value_amount", "comment": "The numerical value of the discount application. A monetary value in decimal format, allowing for precise representation of cents or fractional currency."}, "value_currency_code": {"type": "text", "index": 26, "name": "value_currency_code", "comment": "The three-letter currency code for the discount that represents a world currency used in a store."}, "value_percentage": {"type": "double precision", "index": 27, "name": "value_percentage", "comment": "The percentage discount value that is applied to a line, a number ranging between -100 (free) and 0 (no discount)\n"}, "value_type": {"type": "text", "index": 28, "name": "value_type", "comment": "How the discount value is interpreted (e.g., 'percentage', 'fixed_amount')."}, "unique_key": {"type": "text", "index": 29, "name": "unique_key", "comment": "Unique key representing a discount.\nHashed on 'source_relation', 'discount_code_id', 'discount_id', 'discount_type',\n'code', 'allocation_method', 'target_selection', 'target_type', 'value_amount',\n'value_currency_code', 'value_percentage', 'value_type'.\n"}, "count_orders": {"type": "bigint", "index": 30, "name": "count_orders", "comment": "Count of orders in which this discount code was applied."}, "avg_order_discount_amount": {"type": "double precision", "index": 31, "name": "avg_order_discount_amount", "comment": "Average amount (in shop currency) of discount taken off orders."}, "total_order_discount_amount": {"type": "double precision", "index": 32, "name": "total_order_discount_amount", "comment": "Total monetary amount (in shop currency) of discounts taken off of orders."}, "total_order_line_items_price": {"type": "double precision", "index": 33, "name": "total_order_line_items_price", "comment": "Total monetary amount (in shop currency) of line items for orders that have used this discount."}, "total_order_shipping_cost": {"type": "double precision", "index": 34, "name": "total_order_shipping_cost", "comment": "Total shipping costs for orders that used this discount."}, "total_order_refund_amount": {"type": "double precision", "index": 35, "name": "total_order_refund_amount", "comment": "Total refunded amount (in shop currency) for orders that used this discount code."}, "count_customers": {"type": "bigint", "index": 36, "name": "count_customers", "comment": "Count of distinct customers who placed orders using this discount."}, "count_customer_emails": {"type": "bigint", "index": 37, "name": "count_customer_emails", "comment": "Count of distinct customer emails who placed orders using this discount."}, "total_abandoned_checkout_discount_amount": {"type": "double precision", "index": 38, "name": "total_abandoned_checkout_discount_amount", "comment": "Total monetary amount (in shop currency) of discounts taken off abandoned checkout orders."}, "count_abandoned_checkouts": {"type": "bigint", "index": 39, "name": "count_abandoned_checkouts", "comment": "Count of abandoned checkouts in which this discount code was applied."}, "count_abandoned_checkout_customers": {"type": "bigint", "index": 40, "name": "count_abandoned_checkout_customers", "comment": "Distinct count of customers who applied this discount in a checkout that they abandoned."}, "count_abandoned_checkout_customer_emails": {"type": "bigint", "index": 41, "name": "count_abandoned_checkout_customer_emails", "comment": "Distinct count of customer emails who applied this discount in a checkout that they abandoned."}}, "stats": {"has_stats": {"id": "has_stats", "label": "Has Stats?", "value": false, "include": false, "description": "Indicates whether there are statistics for this table"}}, "unique_id": "model.shopify.shopify_gql__discounts"}, "model.shopify.shopify_gql__inventory_levels": {"metadata": {"type": "BASE TABLE", "schema": "public_shopify", "name": "shopify_gql__inventory_levels", "database": "postgres", "comment": "Model representing the current status of an inventory level in Shopify. Inventory Levels are unique pairings of  inventory items (which have a 1:1 relationship with product variants) and locations. \nInventory Level = Inventory item @ a Location.\nWill also include `PRODUCT_VARIANT` metafields if enabled.\n", "owner": "postgres"}, "columns": {"inventory_level_id": {"type": "integer", "index": 1, "name": "inventory_level_id", "comment": "A globally unique identifier for the inventory level."}, "inventory_item_id": {"type": "integer", "index": 2, "name": "inventory_item_id", "comment": "The ID of the inventory item associated with the inventory level."}, "location_id": {"type": "integer", "index": 3, "name": "location_id", "comment": "The ID of the location that the inventory level belongs to."}, "can_deactivate": {"type": "boolean", "index": 4, "name": "can_deactivate", "comment": "Indicates whether the inventory item can be deactivated at the location."}, "deactivation_alert": {"type": "text", "index": 5, "name": "deactivation_alert", "comment": "Provides an alert message when the inventory item is deactivated at the location."}, "created_at": {"type": "timestamp without time zone", "index": 6, "name": "created_at", "comment": "The date and time when the inventory level was created."}, "updated_at": {"type": "timestamp without time zone", "index": 7, "name": "updated_at", "comment": "The date and time (ISO 8601 format) when the inventory level was last modified."}, "_fivetran_synced": {"type": "timestamp without time zone", "index": 8, "name": "_fivetran_synced", "comment": "The time when a record was last updated by Fivetran."}, "source_relation": {"type": "text", "index": 9, "name": "source_relation", "comment": "The schema or database this record came from if you are making use of the `shopify_union_schemas` or `shopify_union_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}, "sku": {"type": "text", "index": 10, "name": "sku", "comment": "The unique SKU (stock keeping unit) of the inventory item."}, "is_inventory_item_deleted": {"type": "boolean", "index": 11, "name": "is_inventory_item_deleted", "comment": "Boolean representing whether the record was soft-deleted in Shopify."}, "unit_cost_amount": {"type": "double precision", "index": 12, "name": "unit_cost_amount", "comment": "The unit cost associated with the inventory item."}, "unit_cost_currency_code": {"type": "text", "index": 13, "name": "unit_cost_currency_code", "comment": "Currency of the unit cost associated with the inventory item."}, "country_code_of_origin": {"type": "text", "index": 14, "name": "country_code_of_origin", "comment": "The country code (ISO 3166-1 alpha-2) of where the item came from."}, "province_code_of_origin": {"type": "text", "index": 15, "name": "province_code_of_origin", "comment": "The province code (ISO 3166-2 alpha-2) of where the item came from. The province code is only used if the shipping provider for the inventory item is Canada Post."}, "is_shipping_required": {"type": "boolean", "index": 16, "name": "is_shipping_required", "comment": "(DEPRECATED 2025-01-06) Boolean representing whether a customer needs to provide a shipping address when placing an order containing the inventory item."}, "is_inventory_quantity_tracked": {"type": "boolean", "index": 17, "name": "is_inventory_quantity_tracked", "comment": "Boolean representing whether inventory levels are tracked for the item. If true, then the inventory quantity changes are tracked by Shopify."}, "inventory_item_created_at": {"type": "timestamp without time zone", "index": 18, "name": "inventory_item_created_at", "comment": "The date and time (ISO 8601 format) when the inventory item was created."}, "inventory_item_updated_at": {"type": "timestamp without time zone", "index": 19, "name": "inventory_item_updated_at", "comment": "The date and time (ISO 8601 format) when the inventory item was last modified."}, "duplicate_sku_count": {"type": "integer", "index": 20, "name": "duplicate_sku_count", "comment": "The number of inventory items that share the same SKU with this item."}, "harmonized_system_code": {"type": "text", "index": 21, "name": "harmonized_system_code", "comment": "The harmonized system code of the item."}, "inventory_history_url": {"type": "text", "index": 22, "name": "inventory_history_url", "comment": "The URL that points to the inventory history for the item."}, "legacy_resource_id": {"type": "integer", "index": 23, "name": "legacy_resource_id", "comment": "The ID of the corresponding resource in the REST Admin API."}, "measurement_id": {"type": "integer", "index": 24, "name": "measurement_id", "comment": "The unique identifier for the inventory item's measurement."}, "measurement_weight_value": {"type": "double precision", "index": 25, "name": "measurement_weight_value", "comment": "The weight value of the inventory item's measurement."}, "measurement_weight_unit": {"type": "text", "index": 26, "name": "measurement_weight_unit", "comment": "The unit of measurement for the inventory item's weight."}, "is_tracked_editable_locked": {"type": "boolean", "index": 27, "name": "is_tracked_editable_locked", "comment": "Indicates whether the 'tracked' field for the inventory item is locked from editing."}, "tracked_editable_reason": {"type": "text", "index": 28, "name": "tracked_editable_reason", "comment": "Provides the reason why the 'tracked' field for the inventory item is locked from editing."}, "location_name": {"type": "text", "index": 29, "name": "location_name", "comment": "The name of the location."}, "is_location_deleted": {"type": "boolean", "index": 30, "name": "is_location_deleted", "comment": "Boolean representing whether the record was soft-deleted in Shopify."}, "is_location_active": {"type": "boolean", "index": 31, "name": "is_location_active", "comment": "Boolean representing whether the location is active. If true, then the location can be used to sell products, stock inventory, and fulfill orders.\n"}, "address_1": {"type": "text", "index": 32, "name": "address_1", "comment": "The location's street address."}, "address_2": {"type": "text", "index": 33, "name": "address_2", "comment": "The optional second line of the location's street address."}, "city": {"type": "text", "index": 34, "name": "city", "comment": "The city the location is in."}, "country": {"type": "text", "index": 35, "name": "country", "comment": "The country the location is in (two-letter code)."}, "country_code": {"type": "text", "index": 36, "name": "country_code", "comment": "The two-letter code (ISO 3166-1 alpha-2 format) corresponding to country the location is in."}, "country_name": {"type": "text", "index": 37, "name": "country_name", "comment": "The name of the country where the inventory level is located."}, "is_legacy_location": {"type": "boolean", "index": 38, "name": "is_legacy_location", "comment": "Boolean representing whether this is a fulfillment service location. If true, then the location is a fulfillment service location.  If false, then the location was created by the merchant and isn't tied to a fulfillment service.\n"}, "province": {"type": "text", "index": 39, "name": "province", "comment": "The province, state, or district of the location."}, "province_code": {"type": "text", "index": 40, "name": "province_code", "comment": "The province, state, or district code (ISO 3166-2 alpha-2 format) of the location."}, "phone": {"type": "character varying", "index": 41, "name": "phone", "comment": "The phone number of the location. This value can contain special characters, such as - or +."}, "zip": {"type": "integer", "index": 42, "name": "zip", "comment": "The zip or postal code."}, "location_created_at": {"type": "timestamp without time zone", "index": 43, "name": "location_created_at", "comment": "The date and time (ISO 8601 format) when the location was created."}, "location_updated_at": {"type": "timestamp without time zone", "index": 44, "name": "location_updated_at", "comment": "The date and time (ISO 8601 format) when the location was last updated."}, "variant_id": {"type": "integer", "index": 45, "name": "variant_id", "comment": "The unique numeric identifier for the product variant."}, "product_id": {"type": "integer", "index": 46, "name": "product_id", "comment": "The unique numeric identifier for the product."}, "variant_title": {"type": "text", "index": 47, "name": "variant_title", "comment": "The title of the product variant. The title field is a concatenation of the option1, option2, and option3 fields. You can only update title indirectly using the option fields."}, "variant_inventory_policy": {"type": "text", "index": 48, "name": "variant_inventory_policy", "comment": "Whether customers are allowed to place an order for the product variant when it's out of stock."}, "variant_price": {"type": "double precision", "index": 49, "name": "variant_price", "comment": "The price of the product variant in shop currency."}, "variant_media_id": {"type": "integer", "index": 50, "name": "variant_media_id", "comment": "The unique numeric identifier for a product variant's media."}, "is_variant_taxable": {"type": "boolean", "index": 51, "name": "is_variant_taxable", "comment": "Whether a tax is charged when the product variant is sold."}, "variant_barcode": {"type": "text", "index": 52, "name": "variant_barcode", "comment": "The barcode, UPC, or ISBN number for the product."}, "variant_inventory_quantity": {"type": "integer", "index": 53, "name": "variant_inventory_quantity", "comment": "An aggregate of inventory across all locations. To adjust inventory at a specific location, use the InventoryLevel resource."}, "variant_tax_code": {"type": "text", "index": 54, "name": "variant_tax_code", "comment": "This parameter applies only to the stores that have the Avalara AvaTax app installed. Specifies the Avalara tax code for the product variant."}, "variant_created_at": {"type": "timestamp without time zone", "index": 55, "name": "variant_created_at", "comment": "The date and time (ISO 8601 format) when the product variant was created."}, "variant_updated_at": {"type": "timestamp without time zone", "index": 56, "name": "variant_updated_at", "comment": "The date and time when the product variant was last modified. Gets returned in ISO 8601 format."}, "variant_is_available_for_sale": {"type": "boolean", "index": 57, "name": "variant_is_available_for_sale", "comment": "Indicates whether the product variant is available for sale."}, "variant_display_name": {"type": "text", "index": 58, "name": "variant_display_name", "comment": "The display name of the variant, based on the product's title and variant's title."}, "variant_legacy_resource_id": {"type": "integer", "index": 59, "name": "variant_legacy_resource_id", "comment": "The ID of the corresponding resource in the REST Admin API."}, "variant_has_components_required": {"type": "boolean", "index": 60, "name": "variant_has_components_required", "comment": "Indicates whether a product variant requires components."}, "variant_sellable_online_quantity": {"type": "integer", "index": 61, "name": "variant_sellable_online_quantity", "comment": "The total sellable quantity of the variant for online channels."}, "variant_metafield_bea81c1795a612d8fc3a232b156467c1_extra_field": {"type": "text", "index": 62, "name": "variant_metafield_bea81c1795a612d8fc3a232b156467c1_extra_field", "comment": null}, "variant_metafield_bea81c1795a612d8fc3a232b156467c1_gterwbvre": {"type": "text", "index": 63, "name": "variant_metafield_bea81c1795a612d8fc3a232b156467c1_gterwbvre", "comment": null}, "subtotal_sold": {"type": "double precision", "index": 64, "name": "subtotal_sold", "comment": "Total amount (monetary, in shop currency) sold from the inventory level. Includes refunds."}, "quantity_sold": {"type": "bigint", "index": 65, "name": "quantity_sold", "comment": "Total quantity sold from the inventory level. Includes refunds."}, "count_distinct_orders": {"type": "bigint", "index": 66, "name": "count_distinct_orders", "comment": "The number of distinct orders placed from this inventory level."}, "count_distinct_customers": {"type": "bigint", "index": 67, "name": "count_distinct_customers", "comment": "The number of distinct customers (based on customer_id) that have placed orders against this inventory level."}, "count_distinct_customer_emails": {"type": "bigint", "index": 68, "name": "count_distinct_customer_emails", "comment": "The number of distinct customer emails that have placed orders against this inventory level."}, "first_order_timestamp": {"type": "timestamp without time zone", "index": 69, "name": "first_order_timestamp", "comment": "The timetamp of the first order against this inventory level."}, "last_order_timestamp": {"type": "timestamp without time zone", "index": 70, "name": "last_order_timestamp", "comment": "The timestamp of the first order against this inventory level."}, "subtotal_sold_refunds": {"type": "double precision", "index": 71, "name": "subtotal_sold_refunds", "comment": "The monetary amount (in shop currency) of inventory level goods that have been refunded."}, "quantity_sold_refunds": {"type": "double precision", "index": 72, "name": "quantity_sold_refunds", "comment": "The quantity of inventory level goods that have been refunded."}, "count_fulfillment_pending": {"type": "bigint", "index": 73, "name": "count_fulfillment_pending", "comment": "Count of currently pending distinct fulfillments for this inventory level. \"Pending\" = Shopify has created the fulfillment and is waiting for the third-party fulfillment service to transition it to 'open' or 'success'.\n"}, "count_fulfillment_open": {"type": "bigint", "index": 74, "name": "count_fulfillment_open", "comment": "Count of currently open distinct fulfillments for this inventory level. \"Open\" = The fulfillment has been acknowledged by the service and is in processing.\n"}, "count_fulfillment_success": {"type": "bigint", "index": 75, "name": "count_fulfillment_success", "comment": "Count of successful distinct fulfillments for this inventory level. \"Success\" = The fulfillment was successful.\n"}, "count_fulfillment_cancelled": {"type": "bigint", "index": 76, "name": "count_fulfillment_cancelled", "comment": "Count of cancelled distinct fulfillments for this inventory level. \"Cancelled\" = The fulfillment was cancelled.\n"}, "count_fulfillment_error": {"type": "bigint", "index": 77, "name": "count_fulfillment_error", "comment": "Count of distinct fulfillments for this inventory level that encountered an error. \"Error\" = There was an error with the fulfillment request.\n"}, "count_fulfillment_failure": {"type": "bigint", "index": 78, "name": "count_fulfillment_failure", "comment": "Count of distinct fulfillments for this inventory level that failed. \"Failure\" = The fulfillment request failed.\n"}, "incoming_quantity": {"type": "bigint", "index": 79, "name": "incoming_quantity", "comment": "The incoming quantity on its way to a merchant's location. Returns null if the inventory item is not tracked."}, "on_hand_quantity": {"type": "bigint", "index": 80, "name": "on_hand_quantity", "comment": "The total number of units that are physically at a location. The `on_hand` state equals the sum of inventory quantities that  are in the `available`, `committed`, `reserved`, `damaged`, `safety_stock`, and `quality_control` states. Returns null if the inventory item is not tracked.\n"}, "available_quantity": {"type": "bigint", "index": 81, "name": "available_quantity", "comment": "The available quantity that a merchant can sell, determined by coalescing the `quantity` where  inventory_state_name = 'available' from `stg_shopify_gql__inventory_quantity`and `available_quantity`  from the deprecated `stg_shopify_gql__inventory_level`. Returns null if the inventory item is not tracked.\n"}, "committed_quantity": {"type": "bigint", "index": 82, "name": "committed_quantity", "comment": "The number of units that are part of a placed order but aren't fulfilled. When a draft order is created, the inventory isn't committed until the draft order is completed and an order is created. Returns null if the inventory item is not tracked."}, "reserved_quantity": {"type": "bigint", "index": 83, "name": "reserved_quantity", "comment": "The on-hand units that are temporarily set aside. Returns null if the inventory item is 