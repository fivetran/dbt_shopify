abandoned checkouts on this day."}, "count_customer_emails_abandoned_checkout": {"type": "bigint", "index": 52, "name": "count_customer_emails_abandoned_checkout", "comment": "Count of distinct customer emails who abandoned checkouts on this day."}, "count_fulfillment_attempted_delivery": {"type": "bigint", "index": 53, "name": "count_fulfillment_attempted_delivery", "comment": "Count of distinct fulfillments on this day where the delivery of the shipment was attempted, but unable to be completed."}, "count_fulfillment_delayed": {"type": "bigint", "index": 54, "name": "count_fulfillment_delayed", "comment": "Count of delayed distinct fulfillments."}, "count_fulfillment_delivered": {"type": "bigint", "index": 55, "name": "count_fulfillment_delivered", "comment": "Count of successful distinct fulfillments successfully delivered on this day."}, "count_fulfillment_failure": {"type": "bigint", "index": 56, "name": "count_fulfillment_failure", "comment": "Count of failed distinct fulfillments on this day. Something went wrong when pulling tracking information for the shipment, such as the tracking number was invalid or the shipment was canceled."}, "count_fulfillment_in_transit": {"type": "bigint", "index": 57, "name": "count_fulfillment_in_transit", "comment": "Count of distinct fulfillments in transit on this day. Each shipment is being transported between shipping facilities on the way to its destination."}, "count_fulfillment_out_for_delivery": {"type": "bigint", "index": 58, "name": "count_fulfillment_out_for_delivery", "comment": "Count of distinct fulfillments being delivered to their final destination."}, "count_fulfillment_ready_for_pickup": {"type": "bigint", "index": 59, "name": "count_fulfillment_ready_for_pickup", "comment": "Count of distinct fulfillments ready for pickup at a shipping depot."}, "count_fulfillment_picked_up": {"type": "bigint", "index": 60, "name": "count_fulfillment_picked_up", "comment": "Count of distinct fulfillments successfully picked 