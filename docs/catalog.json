onnectors."}, "return_id": {"type": "integer", "index": 4, "name": "return_id", "comment": "The ID of the return associated with this refund, if applicable."}, "order_line_refund_id": {"type": "integer", "index": 5, "name": "order_line_refund_id", "comment": "The ID of the refunded order line item."}, "order_line_id": {"type": "integer", "index": 6, "name": "order_line_id", "comment": "The ID of the associated order line item."}, "order_id": {"type": "integer", "index": 7, "name": "order_id", "comment": "The ID of the order the refund belongs to."}, "customer_id": {"type": "integer", "index": 8, "name": "customer_id", "comment": "The ID of the customer who placed the original order."}, "email": {"type": "text", "index": 9, "name": "email", "comment": "The email address of the customer who placed the original order."}, "order_channel": {"type": "text", "index": 10, "name": "order_channel", "comment": "The channel where the original order was placed (e.g. web, pos)."}, "order_created_at": {"type": "timestamp without time zone", "index": 11, "name": "order_created_at", "comment": "The timestamp when the original order was created."}, "refund_created_at": {"type": "timestamp without time zone", "index": 12, "name": "refund_created_at", "comment": "The timestamp when the refund was created."}, "refund_updated_at": {"type": "timestamp without time zone", "index": 13, "name": "refund_updated_at", "comment": "The timestamp when the refund was last updated."}, "days_to_refund": {"type": "integer", "index": 14, "name": "days_to_refund", "comment": "Number of days between the original order creation date and the refund creation date."}, "refund_note": {"type": "text", "index": 15, "name": "refund_note", "comment": "An optional note attached to the refund by the merchant or staff."}, "staff_user_id": {"type": "integer", "index": 16, "name": "staff_user_id", "comment": "The ID of the staff member who processed the refund."}, "has_return": {"type": "boolean", "index": 17, "name":