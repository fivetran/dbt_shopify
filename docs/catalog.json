nion_databases` variables, respectively. Empty string if you are not using either of these variables to union together multiple Shopify connectors."}, "metafield_bea81c1795a612d8fc3a232b156467c0_different_field": {"type": "text", "index": 11, "name": "metafield_bea81c1795a612d8fc3a232b156467c0_different_field", "comment": null}, "metafield_bea81c1795a612d8fc3a232b156467c0_gwrgew": {"type": "text", "index": 12, "name": "metafield_bea81c1795a612d8fc3a232b156467c0_gwrgew", "comment": null}, "count_orders": {"type": "bigint", "index": 13, "name": "count_orders", "comment": "Count of the distinct orders placed on this day."}, "count_line_items": {"type": "numeric", "index": 14, "name": "count_line_items", "comment": "Count of the line items included in orders placed on this day."}, "avg_line_item_count": {"type": "numeric", "index": 15, "name": "avg_line_item_count", "comment": "Average line item count for orders placed on this day."}, "count_customers": {"type": "bigint", "index": 16, "name": "count_customers", "comment": "Count of distinct customers who placed an order on this day."}, "count_customer_emails": {"type": "bigint", "index": 17, "name": "count_customer_emails", "comment": "Count of distinct customer email addresses who placed an order on this day."}, "order_adjusted_total": {"type": "double precision", "index": 18, "name": "order_adjusted_total", "comment": "Order total adjusted for refunds and other adjustments. The calculation used for this field is as follows: total price listed on the original order (including shipping costs and discounts) + adjustments + adjustments tax - total refunds - refunds tax The order_adjusted_total will equate to the total sales - refunds listed within the transactions table for the order (after currency exchange).\n"}, "avg_order_value": {"type": "double precision", "index": 19, "name": "avg_order_value", "comment": "Average adjusted total per order placed on this day (in shop currency)."}, "shipping_cost": {"type": "double precision", "index": 20, "name": "shipping_cost", "comment": "The shipping cost of the orders placed on this day (in shop currency)."}, "order_adjustment_amount": {"type": "double precision", "index": 21, "name": "order_adjustment_amount", "comment": "Total adjustment amount (in shop currency) applied to the orders placed on this day."}, "order_adjustment_tax_amount": {"type": "double precision", "index": 22, "name": "order_adjustment_tax_amount", "comment": "Total tax applied to adjustments (in shop currency) on the orders placed on this day."}, "refund_subtotal": {"type": "double precision", "index": 23, "name": "refund_subtotal", "comment": "Total refund amount applied to the orders placed on this day."}, "refund_total_tax": {"type": "double precision", "index": 24, "name": "refund_total_tax", "comment": "Total tax applied to the refund on the orders placed on this day (in shop currency)."}, "total_discounts": {"type": "double precision", "index": 25, "name": "total_discounts", "comment": "The total amount of the discount allocated to this day's orders in the shop's currency."}, "avg_discount": {"type": "double precision", "index": 26, "name": "avg_discount", "comment": "Average total discount placed on orders on this day (in shop currency)."}, "shipping_discount_amount": {"type": "double precision", "index": 27, "name": "shipping_discount_amount", "comment": "The total amount of discount (in shop currency) allocated toward shipping for orders placed on this day."}, "avg_shipping_discount_amount": {"type": "double precision", "index": 28, "name": "avg_shipping_discount_amount", "comment": "Average discount amount (in shop currency) allocated toward shipping on orders placed on this day."}, "percentage_calc_discount_amount": {"type": "double precision", "index": 29, "name": "percentage_calc_discount_amount", "comment": "The total amount of discount (in shop currency) allocated via a percentage-based discount for orders placed on this day."}, "avg_percentage_calc_di