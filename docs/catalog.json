mlit App](https://fivetran-billing-model.streamlit.app/). Visit the app for more details.", "owner": "postgres"}, "columns": {"header_id": {"type": "integer", "index": 1, "name": "header_id", "comment": "Id of corresponding order."}, "line_item_id": {"type": "numeric(28,6)", "index": 2, "name": "line_item_id", "comment": "Order line item id."}, "line_item_index": {"type": "numeric(28,6)", "index": 3, "name": "line_item_index", "comment": "Unique index of each line item id for each order."}, "record_type": {"type": "text", "index": 4, "name": "record_type", "comment": "header or line_item"}, "created_at": {"type": "timestamp without time zone", "index": 5, "name": "created_at", "comment": "When the order was created"}, "currency": {"type": "text", "index": 6, "name": "currency", "comment": "Currency used in the order."}, "header_status": {"type": "text", "index": 7, "name": "header_status", "comment": "Status of the order."}, "product_id": {"type": "numeric(28,6)", "index": 8, "name": "product_id", "comment": "Product ID"}, "product_name": {"type": "text", "index": 9, "name": "product_name", "comment": "Product name"}, "transaction_type": {"type": "text", "index": 10, "name": "transaction_type", "comment": "Transaction type (Charge, Refund, etc)"}, "billing_type": {"type": "text", "index": 11, "name": "billing_type", "comment": "NA for Shopify."}, "product_type": {"type": "text", "index": 12, "name": "product_type", "comment": "Product type"}, "quantity": {"type": "numeric(28,6)", "index": 13, "name": "quantity", "comment": "The number of units of this line item."}, "unit_amount": {"type": "numeric(28,6)", "index": 14, "name": "unit_amount", "comment": "Amount per unit, or the price."}, "discount_amount": {"type": "double precision", "index": 15, "name": "discount_amount", "comment": "The discount amount associated with this order."}, "tax_amount": {"type": "double precision", "index": 16, "name": "tax_amount", "comment": "The tax amount associated with this order."}