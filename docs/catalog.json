o the orders placed on this day."}, "order_adjustment_tax_amount": {"type": "double precision", "index": 20, "name": "order_adjustment_tax_amount", "comment": "Total tax applied to adjustments (in shop currency) on the orders placed on this day."}, "refund_subtotal": {"type": "bigint", "index": 21, "name": "refund_subtotal", "comment": "Total refund amount applied to the orders placed on this day."}, "refund_total_tax": {"type": "double precision", "index": 22, "name": "refund_total_tax", "comment": "Total tax applied to the refund on the orders placed on this day (in shop currency)."}, "total_discounts": {"type": "double precision", "index": 23, "name": "total_discounts", "comment": "The total amount of the discount allocated to this day's orders in the shop's currency."}, "avg_discount": {"type": "double precision", "index": 24, "name": "avg_discount", "comment": "Average total discount placed on orders on this day (in shop currency)."}, "shipping_discount_amount": {"type": "double precision", "index": 25, "name": "shipping_discount_amount", "comment": "The total amount of discount (in shop currency) allocated toward shipping for orders placed on this day."}, "avg_shipping_discount_amount": {"type": "double precision", "index": 26, "name": "avg_shipping_discount_amount", "comment": "Average discount amount (in shop currency) allocated toward shipping on orders placed on this day."}, "percentage_calc_discount_amount": {"type": "double precision", "index": 27, "name": "percentage_calc_discount_amount", "comment": "The total amount of discount (in shop currency) allocated via a percentage-based discount for orders placed on this day."}, "avg_percentage_calc_discount_amount": {"type": "double precision", "index": 28, "name": "avg_percentage_calc_discount_amount", "comment": "Average discount amount (in shop currency) allocated via a percentage-based-discount on orders placed on this day."}, "fixed_amount_discount_amount": {"type": "double precision", "index": 29, "name": "fixed_amount_discount_amount", "comment": "The total amount of discount (in shop currency) allocated via a fixed-amount discount for orders placed on this day."}, "avg_fixed_amount_discount_amount": {"type": "double precision", "index": 30, "name": "avg_fixed_amount_discount_amount", "comment": "Average discount amount (in shop currency) allocated via a fixed-amount-discount on orders placed on this day."}, "count_discount_codes_applied": {"type": "numeric", "index": 31, "name": "count_discount_codes_applied", "comment": "Distinct discount codes applied by customers on orders for this day."}, "count_locations_ordered_from": {"type": "bigint", "index": 32, "name": "count_locations_ordered_from", "comment": "Distinct locations with orders placed against them on this day."}, "count_orders_with_discounts": {"type": "bigint", "index": 33, "name": "count_orders_with_discounts", "comment": "Count of orders in which a discount was applied."}, "count_orders_with_refunds": {"type": "bigint", "index": 34, "name": "count_orders_with_refunds", "comment": "Count of orders in which there was a refund."}, "first_order_timestamp": {"type": "timestamp without time zone", "index": 35, "name": "first_order_timestamp", "comment": "Timestamp of the first order of the day for the shop."}, "last_order_timestamp": {"type": "timestamp without time zone", "index": 36, "name": "last_order_timestamp", "comment": "Timestamp of the last order of the day for the shop."}, "quantity_sold": {"type": "bigint", "index": 37, "name": "quantity_sold", "comment": "Total quantity sold from the inventory level. Includes refunds."}, "quantity_refunded": {"type": "numeric", "index": 38, "name": "quantity_refunded", "comment": "The quantity of goods ORDERED on this day that have been refunded."}, "quantity_net": {"type": "numeric", "index": 39, "name": "quantity_net", "comment": "Net quantity sold from this shop on this day. Excludes refunds."}, "avg_quantity_sold": {"type": "bigint", "index": 40, "name": 